<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    
    <persistence-unit name="hibernate_example" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>org.example.hibernate.entity.Productos</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/productos?serverTimezone=UTC"/>
            <property name="jakarta.persistence.jdbc.user" value="superadmin"/>
            <property name="jakarta.persistence.jdbc.password" value="19851831"/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
            <property name="hibernate.show_sql" value="true"/>

        </properties>
    </persistence-unit>
    
</persistence>